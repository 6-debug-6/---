# ==================== 环境变量 & 密钥 ====================
# .env 文件包含 API Key、数据库密码等敏感信息，严禁提交
.env
*.env
!.env.example

# ==================== Python ====================
__pycache__/
*.py[cod]
*.egg-info/
dist/
build/
*.egg
.eggs/
*.whl
venv/
.venv/
env/

# ==================== 数据库 & 数据文件 ====================
# SQLite 数据库文件（包含用户数据，不应提交）
*.db
*.sqlite3
data/

# ==================== ChromaDB 向量库 ====================
# ChromaDB 持久化索引（运行时生成，无需版本控制）
chroma_data/

# ==================== 文件上传 ====================
# 用户上传的文件（运行时数据）
uploads/

# ==================== IDE & 编辑器 ====================
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ==================== Node.js ====================
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ==================== 前端构建产物 ====================
frontend/dist/

# ==================== 测试 & 覆盖率 ====================
.coverage
htmlcov/
.pytest_cache/
.tox/

# ==================== 日志 ====================
*.log
logs/

# ==================== 临时文件 ====================
*.tmp
*.temp
